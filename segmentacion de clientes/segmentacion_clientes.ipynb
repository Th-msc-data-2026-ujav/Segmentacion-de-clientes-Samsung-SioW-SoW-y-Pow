    "class TukeyWinsorizer(BaseEstimator, TransformerMixin):\n",
    "    def __init__(self, k=3):\n",
    "        self.k = k\n",
    "        self.caps_ = None\n",
    "\n",
    "    def fit(self, X, y=None):\n",
    "        X = pd.DataFrame(X).copy()\n",
    "\n",
    "        q1 = X.quantile(0.25)\n",
    "        q3 = X.quantile(0.75)\n",
    "        iqr = q3 - q1\n",
    "\n",
    "        self.caps_ = q3 + self.k * iqr\n",
    "        return self\n",
    "\n",
    "    def transform(self, X):\n",
    "        X = pd.DataFrame(X).copy()\n",
    "        return X.clip(upper=self.caps_, axis=1)"
   ]
