    "\n",
    "\n",
    "# 1. Convertir a matriz booleana (True si es faltante, False si está presente)\n",
    "missing_matrix = purchases_samsung .isnull()\n",
    "\n",
    "# 2. AGRUPAR por patrones idénticos de faltantes y contar cuántas filas tienen cada patrón\n",
    "# Esto reduce tus 19,706 filas a solo unas cuantas combinaciones únicas\n",
    "patrones = (\n",
    "    missing_matrix.groupby(list(missing_matrix.columns))\n",
    "    .size()\n",
    "    .reset_index(name=\"Frecuencia_Filas\")\n",
    ")\n",
    "\n",
    "# 3. Ordenar los patrones: Primero los que tienen menos faltantes totales\n",
    "# Calculamos cuántas variables faltan en cada patrón (suma horizontal)\n",
    "patrones[\"Total_Faltantes_Por_Patron\"] = patrones[purchases_samsung .columns].sum(axis=1)\n",
    "patrones = patrones.sort_values(\n",
    "    by=[\"Total_Faltantes_Por_Patron\", \"Frecuencia_Filas\"],\n",
    "    ascending=[True, False],\n",
    ")\n",
    "\n",
    "# 4Ordenar las columnas (variables): De menos faltantes a más faltantes (Izquierda a Derecha)\n",
    "total_faltantes_columna = missing_matrix.sum().sort_values()\n",
    "columnas_ordenadas = total_faltantes_columna.index\n",
    "\n",
    "# Reorganizar nuestra matriz agrupada con el orden correcto\n",
    "matriz_plot = patrones[columnas_ordenadas].copy()\n",
    "conteos_filas = patrones[\"Frecuencia_Filas\"].values\n",
    "conteos_cols_patron = patrones[\"Total_Faltantes_Por_Patron\"].values\n",
    "conteos_totales_cols = total_faltantes_columna.values\n",
    "\n",
    "# 5. DIBUJAR EL GRÁFICO (Estilo Cuadrícula de la segunda imagen)\n",
    "fig, ax = plt.subplots(figsize=(14, 12))\n",
    "\n",
    "# Colores exactos: Azul para datos presentes (False), Rosa/Magenta para faltantes (True)\n",
    "cmap = sns.color_palette([\"#4682B4\", \"#D16587\"])\n",
    "\n",
    "# Dibujamos la cuadrícula limpia con bordes negros (linewidths=0.5)\n",
    "sns.heatmap(\n",
    "    matriz_plot,\n",
    "    cmap=cmap,\n",
    "    cbar=False,\n",
    "    linewidths=0.5,\n",
    "    linecolor=\"black\",\n",
    "    ax=ax,\n",
    "    yticklabels=False,\n",
    ")\n",
    "\n",
    "# Ajustar etiquetas del eje X arriba (como en tu imagen objetivo)\n",
    "ax.xaxis.tick_top()\n",
    "ax.set_xticklabels(columnas_ordenadas, rotation=90, fontsize=9)\n",
    "\n",
    "# 7. AGREGAR LOS NÚMEROS DE LOS BORDES\n",
    "\n",
    "# Eje Izquierdo: Frecuencia de filas con ese patrón\n",
    "for i, count in enumerate(conteos_filas):\n",
    "    ax.text(-0.5, i + 0.5, str(count), va=\"center\", ha=\"right\", fontsize=10)\n",
    "\n",
    "# Eje Derecho: Cuántas variables faltan en esa fila/patrón\n",
    "for i, count in enumerate(conteos_cols_patron):\n",
    "    ax.text(\n",
    "        len(columnas_ordenadas) + 0.5,\n",
    "        i + 0.5,\n",
    "        str(count),\n",
    "        va=\"center\",\n",
    "        ha=\"left\",\n",
    "        fontsize=10,\n",
    "    )\n",
    "\n",
    "# Eje Inferior: Total de faltantes por cada variable independiente\n",
    "for j, count in enumerate(conteos_totales_cols):\n",
    "    ax.text(\n",
    "        j + 0.5,\n",
    "        len(patrones) + 0.5,\n",
    "        str(count),\n",
    "        va=\"top\",\n",
    "        ha=\"center\",\n",
    "        fontsize=10,\n",
    "    )\n",
    "\n",
    "# Título inferior\n",
    "plt.title(\"Identificación de faltantes por variable 'Purchases_Samsung'\", y=-0.15, fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
