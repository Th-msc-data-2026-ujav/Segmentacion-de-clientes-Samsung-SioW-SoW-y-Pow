    "X_pre = preprocessor.fit_transform(df)\n",
    "\n",
    "X_pre = pd.DataFrame(\n",
    "    X_pre,\n",
    "    columns=numeric_columns + ordinal_cols + nominal_columns\n",
    ")\n",
    "\n",
    "# Asegurar tipos correctos\n",
    "for col in numeric_columns + ordinal_cols:\n",
    "    X_pre[col] = pd.to_numeric(X_pre[col], errors=\"coerce\")\n",
    "\n",
    "for col in nominal_columns:\n",
    "    X_pre[col] = X_pre[col].astype(str)\n",
    "\n",
    "# =========================\n",
    "# 2. Máscara categórica para Gower\n",
    "# =========================\n",
    "\n",
    "cat_features = (\n",
    "    [False] * len(numeric_columns) +\n",
    "    [False] * len(ordinal_cols) +\n",
    "    [True] * len(nominal_columns)\n",
    ")\n",
    "\n",
    "print(X_pre.shape)\n",
    "print(len(cat_features))\n",
    "print(cat_features)\n",
    "\n",
    "# =========================\n",
    "# 3. Matriz de distancia Gower\n",
    "# =========================\n",
    "\n",
    "D_gower = GowerTransformer(cat_features).fit_transform(X_pre)\n",
    "\n",
    "D_gower = np.asarray(D_gower, dtype=float)\n",
    "np.fill_diagonal(D_gower, 0)\n",
    "\n",
    "# =========================\n",
    "# 4. Evaluación K-Medoids para varios k\n",
    "# =========================\n",
    "\n",
    "resultados_kmedoids = []\n",
    "\n",
    "for k in range(2, 8):\n",
    "\n",
    "    modelo = KMedoids(\n",
    "        n_clusters=k,\n",
    "        metric=\"precomputed\",\n",
    "        method=\"pam\",\n",
    "        init=\"k-medoids++\",\n",
    "        random_state=123\n",
    "    )\n",
    "\n",
    "    labels = modelo.fit_predict(D_gower)\n",
    "\n",
    "    conteo = pd.Series(labels).value_counts().sort_index()\n",
    "\n",
    "    silhouette = silhouette_score(\n",
    "        D_gower,\n",
    "        labels,\n",
    "        metric=\"precomputed\"\n",
    "    )\n",
    "\n",
    "    resultados_kmedoids.append({\n",
    "        \"k\": k,\n",
    "        \"inertia\": modelo.inertia_,\n",
    "        \"silhouette_gower\": silhouette,\n",
    "        \"min_cluster\": conteo.min(),\n",
    "        \"max_cluster\": conteo.max(),\n",
    "        \"n_clusters_reales\": conteo.shape[0],\n",
    "        \"distribucion\": conteo.to_dict()\n",
    "    })\n",
    "\n",
    "tabla_kmedoids = pd.DataFrame(resultados_kmedoids)\n",
    "\n",
    "tabla_kmedoids = tabla_kmedoids.sort_values(\n",
    "    by=[\"silhouette_gower\", \"inertia\"],\n",
    "    ascending=[False, True]\n",
    ").reset_index(drop=True)\n",
    "\n",
    "tabla_kmedoids"
   ]
  },
