   "source": [
    "# =========================\n",
    "# 1. Preprocesar datos\n",
    "# =========================\n",
    "\n",
    "X_pre = preprocessor.fit_transform(df)\n",
    "\n",
    "# Convertir a DataFrame para manejar mejor tipos y columnas\n",
    "X_pre = pd.DataFrame(\n",
    "    X_pre,\n",
    "    columns=numeric_columns + ordinal_cols + nominal_columns\n",
    ")\n",
    "\n",
    "# Asegurar tipos correctos\n",
    "for col in numeric_columns + ordinal_cols:\n",
    "    X_pre[col] = pd.to_numeric(X_pre[col], errors=\"coerce\")\n",
    "\n",
    "for col in nominal_columns:\n",
    "    X_pre[col] = X_pre[col].astype(str)\n",
    "\n",
    "# =========================\n",
    "# 2. Índices categóricos para K-Prototypes\n",
    "# =========================\n",
    "\n",
    "cat_idx = list(\n",
    "    range(\n",
    "        len(numeric_columns) + len(ordinal_cols),\n",
    "        len(numeric_columns) + len(ordinal_cols) + len(nominal_columns)\n",
    "    )\n",
    ")\n",
    "\n",
    "cat_idx\n",
    "\n",
    "# =========================\n",
    "# 3. Máscara categórica para Gower\n",
    "# =========================\n",
    "\n",
    "cat_features_gower = [False] * X_pre.shape[1]\n",
    "\n",
    "for idx in cat_idx:\n",
    "    cat_features_gower[idx] = True\n",
    "\n",
    "cat_features_gower\n",
    "\n",
    "# =========================\n",
    "# 4. Matriz Gower\n",
    "# =========================\n",
    "\n",
    "D_gower = GowerTransformer(cat_features_gower).fit_transform(X_pre)\n",
    "\n",
    "D_gower = np.asarray(D_gower, dtype=float)\n",
    "np.fill_diagonal(D_gower, 0)\n",
    "\n",
    "# =========================\n",
    "# 5. Evaluación K-Prototypes para varios k\n",
    "# =========================\n",
    "\n",
    "resultados_kproto = []\n",
    "\n",
    "for k in range(2, 11):\n",
    "\n",
    "    modelo = KPrototypes(\n",
    "        n_clusters=k,\n",
    "        init=\"Huang\",\n",
    "        random_state=123,\n",
    "        n_init=10,\n",
    "        verbose=0\n",
    "    )\n",
    "\n",
    "    labels = modelo.fit_predict(\n",
    "        X_pre,\n",
    "        categorical=cat_idx\n",
    "    )\n",
    "\n",
    "    conteo = pd.Series(labels).value_counts().sort_index()\n",
    "\n",
    "    silhouette = silhouette_score(\n",
    "        D_gower,\n",
    "        labels,\n",
    "        metric=\"precomputed\"\n",
    "    )\n",
    "\n",
    "    resultados_kproto.append({\n",
    "        \"k\": k,\n",
    "        \"cost\": modelo.cost_,\n",
    "        \"silhouette_gower\": silhouette,\n",
    "        \"min_cluster\": conteo.min(),\n",
    "        \"max_cluster\": conteo.max(),\n",
    "        \"n_clusters_reales\": conteo.shape[0],\n",
    "        \"distribucion\": conteo.to_dict()\n",
    "    })\n",
    "\n",
    "tabla_kprototypes = pd.DataFrame(resultados_kproto)\n",
    "\n",
    "tabla_kprototypes = tabla_kprototypes.sort_values(\n",
    "    by=\"silhouette_gower\",\n",
    "    ascending=False\n",
    ").reset_index(drop=True)\n",
    "\n",
    "tabla_kprototypes"
   ]
  },
