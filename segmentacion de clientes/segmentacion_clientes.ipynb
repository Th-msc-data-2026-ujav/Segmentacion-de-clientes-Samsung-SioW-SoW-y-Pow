    "pipeline_hdbscan = Pipeline([\n",
    "    (\"preprocessor\", preprocessor),\n",
    "    (\"gower\", GowerTransformer(cat_features)),\n",
    "    (\"hdbscan\", hdbscan.HDBSCAN(\n",
    "        min_cluster_size=5,\n",
    "        metric=\"precomputed\"\n",
    "    ))\n",
    "])\n",
    "\n",
    "pipeline_hdbscan.fit(df)"
   ]
